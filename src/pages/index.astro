---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';
---

<Base>
  <section class="hero-section">
    {/* The entire hero is one VectoUI canvas (zero per-element DOM). */}
    <canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

    {
      /* Accessible / no-JS / SEO text. The canvas draws the same content; its
        interactive controls project their own a11y shadow nodes at runtime. */
    }
    <div class="hero-fallback sr-only">
      <h1>VectoUI — the Zero-DOM canvas UI engine an AI agent can actually drive</h1>
      <p>
        Zero-DOM, accessible, agent-native. The canvas UI runtime that screen readers — and AI
        agents — can operate by role.
      </p>
      <a href="/demos/">Demos</a>
      <a href={SITE.github}>GitHub</a>
    </div>
  </section>

  <section class="features-section container">
    <h2 class="section-title">More than a canvas</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">👁️</div>
        <h3>Agent-native &amp; accessible</h3>
        <p>
          Every interactive component projects a real, transparent DOM shadow node. A pure-canvas
          page is still read by screen readers and driven by Playwright / AI agents with <code
            >getByRole().click()</code
          > — something other canvas frameworks can't do.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🍃</div>
        <h3>Zero-DOM, zero reflow</h3>
        <p>
          The whole UI tree lives in one <code>&lt;canvas&gt;</code>. Layout, hit-testing and
          animation are pure math in JS/Workers — no browser reflow or style recalc. DOM-node count
          stays flat while animating.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔤</div>
        <h3>Typography that reflows</h3>
        <p>
          A cold/hot <code>LayoutEngine</code>: measure once, re-wrap on resize or browser zoom
          without re-measuring. Inline rich text, links, exclusion flow and streaming/typewriter
          incremental layout included.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⚡</div>
        <h3>Honest performance</h3>
        <p>
          Real, reproducible benchmarks — measured in your own browser. The danmaku demo holds ~5000
          live comments at 60+fps where DOM-based danmaku chokes past ~200; every demo ships an
          Export-report button that reads real-GPU numbers.
        </p>
      </div>
    </div>
  </section>
</Base>

<script>
  import '../hero';
</script>
