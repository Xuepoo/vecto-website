---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <!-- Spine and Arrowhead -->
  <path d="M16 28 L16 6"></path>
  <path d="M12 10 L16 6 L20 10"></path>

  <!-- Top Slant -->
  <path d="M22 6 L10 10"></path>

  <!-- Middle Crossbar -->
  <path d="M8 15 L24 15"></path>

  <!-- Left Leg (Bézier Curve) -->
  <path d="M16 15 C13 19 9 23 6 26"></path>

  <!-- Right Leg (Bézier Curve) -->
  <path d="M16 15 C19 19 23 23 26 26"></path>

  <!-- Tangent Handles (Dotted lines representing curve curvature control) -->
  <line
    x1="26"
    y1="26"
    x2="30"
    y2="24"
    stroke="currentColor"
    stroke-opacity="0.4"
    stroke-width="1"
    stroke-dasharray="1.5 1.5"></line>
  <circle cx="30" cy="24" r="1" fill="none" stroke="currentColor" stroke-width="1"></circle>

  <line
    x1="6"
    y1="26"
    x2="2"
    y2="24"
    stroke="currentColor"
    stroke-opacity="0.4"
    stroke-width="1"
    stroke-dasharray="1.5 1.5"></line>
  <circle cx="2" cy="24" r="1" fill="none" stroke="currentColor" stroke-width="1"></circle>

  <!-- Vector Control Anchors (Squares) -->
  <rect x="15" y="27" width="2" height="2" fill="currentColor" stroke="none"></rect>
  <rect x="21" y="5" width="2" height="2" fill="currentColor" stroke="none"></rect>
  <rect x="9" y="9" width="2" height="2" fill="currentColor" stroke="none"></rect>
  <rect x="7" y="14" width="2" height="2" fill="currentColor" stroke="none"></rect>
  <rect x="23" y="14" width="2" height="2" fill="currentColor" stroke="none"></rect>
  <rect x="5" y="25" width="2" height="2" fill="currentColor" stroke="none"></rect>
  <rect x="25" y="25" width="2" height="2" fill="currentColor" stroke="none"></rect>
</svg>
