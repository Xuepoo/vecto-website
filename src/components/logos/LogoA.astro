---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <!-- Cartesian Grid background -->
  <line x1="0" y1="16" x2="32" y2="16" stroke="currentColor" stroke-opacity="0.1" stroke-width="0.8"
  ></line>
  <line x1="16" y1="0" x2="16" y2="32" stroke="currentColor" stroke-opacity="0.1" stroke-width="0.8"
  ></line>
  <circle
    cx="16"
    cy="16"
    r="11"
    stroke="currentColor"
    stroke-opacity="0.08"
    stroke-width="0.8"
    stroke-dasharray="1.5 1.5"></circle>

  <!-- "矢" Strokes -->
  <path d="M16 28 L16 6"></path>
  <path d="M12 10 L16 6 L20 10"></path>
  <path d="M21 6 L11 9"></path>
  <path d="M8 14 L24 14"></path>
  <path d="M16 14 L8 24"></path>
  <path d="M16 14 L24 24"></path>

  <!-- Anchor Points -->
  <circle cx="16" cy="28" r="1.5" fill="currentColor" stroke="none"></circle>
  <circle cx="16" cy="6" r="1.5" fill="currentColor" stroke="none"></circle>
  <circle cx="21" cy="6" r="1.5" fill="currentColor" stroke="none"></circle>
  <circle cx="11" cy="9" r="1.5" fill="currentColor" stroke="none"></circle>
  <circle cx="8" cy="14" r="1.5" fill="currentColor" stroke="none"></circle>
  <circle cx="24" cy="14" r="1.5" fill="currentColor" stroke="none"></circle>
  <circle cx="8" cy="24" r="1.5" fill="currentColor" stroke="none"></circle>
  <circle cx="24" cy="24" r="1.5" fill="currentColor" stroke="none"></circle>
</svg>
